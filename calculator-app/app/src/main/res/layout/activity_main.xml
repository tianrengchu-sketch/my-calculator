<?xml version=""1.0"" encoding=""utf-8""?>
<LinearLayout xmlns:android=""http://schemas.android.com/apk/res/android""
    android:layout_width=""match_parent""
    android:layout_height=""match_parent""
    android:orientation=""vertical""
    android:padding=""16dp""
    android:background=""#f5f5f5"">

    <!-- 显示区域 -->
    <TextView
        android:id=""@+id/tvDisplay""
        android:layout_width=""match_parent""
        android:layout_height=""0dp""
        android:layout_weight=""1""
        android:gravity=""end|center_vertical""
        android:textSize=""48sp""
        android:textColor=""#000000""
        android:background=""#ffffff""
        android:padding=""16dp""
        android:text=""0"" />

    <!-- 按钮区域 -->
    <GridLayout
        android:layout_width=""match_parent""
        android:layout_height=""0dp""
        android:layout_weight=""1""
        android:columnCount=""4""
        android:rowCount=""5""
        android:layout_marginTop=""8dp"">

        <!-- 第1行 -->
        <Button android:text=""C"" android:id=""@+id/btnClear"" android:textSize=""20sp"" android:background=""@drawable/button_bg""/>
        <Button android:text=""±"" android:id=""@+id/btnNegate"" android:textSize=""20sp"" android:background=""@drawable/button_bg""/>
        <Button android:text=""%"" android:id=""@+id/btnPercent"" android:textSize=""20sp"" android:background=""@drawable/button_bg""/>
        <Button android:text=""÷"" android:id=""@+id/btnDivide"" android:textSize=""24sp"" android:background=""@drawable/button_op_bg""/>

        <!-- 第2行 -->
        <Button android:text=""7"" android:id=""@+id/btn7"" android:textSize=""24sp"" android:background=""@drawable/button_bg""/>
        <Button android:text=""8"" android:id=""@+id/btn8"" android:textSize=""24sp"" android:background=""@drawable/button_bg""/>
        <Button android:text=""9"" android:id=""@+id/btn9"" android:textSize=""24sp"" android:background=""@drawable/button_bg""/>
        <Button android:text=""×"" android:id=""@+id/btnMultiply"" android:textSize=""24sp"" android:background=""@drawable/button_op_bg""/>

        <!-- 第3行 -->
        <Button android:text=""4"" android:id=""@+id/btn4"" android:textSize=""24sp"" android:background=""@drawable/button_bg""/>
        <Button android:text=""5"" android:id=""@+id/btn5"" android:textSize=""24sp"" android:background=""@drawable/button_bg""/>
        <Button android:text=""6"" android:id=""@+id/btn6"" android:textSize=""24sp"" android:background=""@drawable/button_bg""/>
        <Button android:text=""-"" android:id=""@+id/btnMinus"" android:textSize=""28sp"" android:background=""@drawable/button_op_bg""/>

        <!-- 第4行 -->
        <Button android:text=""1"" android:id=""@+id/btn1"" android:textSize=""24sp"" android:background=""@drawable/button_bg""/>
        <Button android:text=""2"" android:id=""@+id/btn2"" android:textSize=""24sp"" android:background=""@drawable/button_bg""/>
        <Button android:text=""3"" android:id=""@+id/btn3"" android:textSize=""24sp"" android:background=""@drawable/button_bg""/>
        <Button android:text=""+"" android:id=""@+id/btnPlus"" android:textSize=""28sp"" android:background=""@drawable/button_op_bg""/>

        <!-- 第5行 -->
        <Button android:text=""0"" android:id=""@+id/btn0"" android:textSize=""24sp"" android:layout_columnSpan=""2"" android:layout_gravity=""fill"" android:background=""@drawable/button_bg""/>
        <Button android:text=""."" android:id=""@+id/btnDot"" android:textSize=""24sp"" android:background=""@drawable/button_bg""/>
        <Button android:text==="="" android:id=""@+id/btnEquals"" android:textSize=""24sp"" android:background=""@drawable/button_eq_bg""/>

    </GridLayout>

</LinearLayout>
